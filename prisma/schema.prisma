generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "admin"]
}

// NextAuth Required Models (Schema: admin)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@schema("admin")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("admin")
}

model Admin {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  hashedPassword String?

  dataDeEntrada  DateTime  @default(now())
  dataDeUltimoAcesso DateTime  @updatedAt

  @@map("Admin")
  @@schema("admin")
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String?   @unique
  emailVerified      DateTime?
  image              String?
  hashedPassword     String?   // Para login com email/senha
  telefone           String?
  pais               String?
  aniversario        DateTime?
  localizacao        String?
  statusUltimoPedido String?
  
  dataDeEntrada      DateTime  @default(now())
  dataDeUltimoAcesso DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  pedidos            Pedido[]
  comentarios        Comentario[] // Relation to comments

  @@schema("admin")
}

model Pedido {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  status      String   @default("PENDENTE") // PENDENTE, PAGO, ENVIADO, ENTREGUE
  produtosIds String[] // IDs dos produtos comprados
  totalAmmount Float    @default(0) // Total cobrado
  
  dataCompra  DateTime @default(now())
  dataEntrega DateTime?

  @@schema("admin")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@schema("admin")
}

// Produtos (Schema: public)
model Produto {
  id              String   @id @default(cuid())
  nome            String
  handle          String   @unique
  descricao       String   @db.Text
  preco           Float
  precoOriginal   Float?
  collection      String
  fotoPrincipal   String?  // Foto de destaque (Thumbnail)
  fotos           String[] // Outras fotos do grid
  videos          String[] // URLs de vídeos no R2
  
  // Avaliações (Manual Override)
  totalAvaliacoes Int      @default(0)
  mediaAvaliacoes Float    @default(5.0)

  comentarios     Comentario[] // Relation to actual comments if present

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@schema("public")
}

model Comentario {
  id        String   @id @default(cuid())
  rating    Int      @default(5)
  texto     String   @db.Text
  createdAt DateTime @default(now())

  // Relations
  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName String? // Cache user name at time of comment

  @@schema("public")
}

model Collection {
  id          String   @id @default(cuid())
  name        String   @unique
  handle      String   @unique
  description String?  @db.Text
  image       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("public")
}
